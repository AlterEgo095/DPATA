# DPATA v2.0 - Environment Configuration
# PHASE 1 HARDING SÉCURITÉ

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ============================================================================
# SECURITY CRITICAL - MUST BE SET IN PRODUCTION
# ============================================================================

# JWT Secret (minimum 32 characters, generate with: openssl rand -base64 32)
JWT_SECRET=dpata-production-secret-key-2024-256-bit-secure-random-v2

# Password salt for legacy SHA256 verification during migration
PASSWORD_SALT=dpata-salt-2024-migration-only

# Cookie domain (optional, for multi-subdomain setups)
# COOKIE_DOMAIN=.unikin.ac.cd

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# OPTIONAL: External Services (for future use)
# ============================================================================
# OCR_API_KEY=
# OPENAI_API_KEY=
# REDIS_URL=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
